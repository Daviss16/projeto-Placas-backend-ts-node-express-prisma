// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url = env ("DATABASE_URL")
}

model Placa {
    @@map("placas")

    id String @id
    placaCinza String @unique
    placaMercoS String @unique
    estado String
    regiao String
}
